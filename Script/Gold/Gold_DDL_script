 SQL SCRIPT -Gold.Dim_Customers
--------------------------------------------------------------------------------------------------------------------------------------

--DIMENSION TABLE(DETAILS OF SOURCE SYSTEM)
CREATE VIEW Gold.Dim_Customers AS -------creating view
SELECT 
ROW_NUMBER() OVER (ORDER BY ci.cst_id) AS SURRO_KEY,---SURROGTE KEY(system generated unique identifier assined to each row)
ci.cst_id AS CUSTOMER_ID,
ci.cst_key AS CUSTOMER_KEY,
ci.cst_firstname AS CUSTOMER_FIRST_NAME,
ci.cst_lastname AS CUSTOMER_LAST_NAME,
LO.CNTRY AS COUNTRY,
ci.cst_marital_status AS MARITAL_STATUS,
CASE 
	WHEN ci.cst_gndr !='N/A' THEN ci.cst_gndr----CRM IS MASTER FOR GENDER
	ELSE COALESCE(ca.GEN,'N/A') -----COALESCE TO REPLACE NULL VALUES WITH NEW VALUE
	END GENDER,
ca.BDATE AS BIRTH_DATE,
ci.cst_create_date AS CREATE_DATE
FROM  SILVER.CRM_cust_info ci
LEFT JOIN silver.erp_cust_AZ12 ca
ON
ci.cst_key=ca.cid
LEFT JOIN silver.erp_LOC_A101 LO
ON
ci.cst_key =lo.CID


--------DATA INTEGRATION BECOZ TWO GENDER INFORMATION AVAIABLE DATA FROM 2 TABLES-----------
SELECT 
DISTINCT
ci.cst_gndr,
ca.GEN,
CASE 
	WHEN ci.cst_gndr !='N/A' THEN ci.cst_gndr----CRM IS MASTER FOR GENDER
	ELSE COALESCE(ca.GEN,'N/A') -----COALESCE TO REPLACE NULL VALUES WITH NEW VALUE
	END new_gndr

FROM  SILVER.CRM_cust_info ci
LEFT JOIN silver.erp_cust_AZ12 ca
ON
ci.cst_key=ca.cid
ORDER BY 1,2
