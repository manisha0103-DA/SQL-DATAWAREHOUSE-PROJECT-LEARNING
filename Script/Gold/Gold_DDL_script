--------------------------------------------------------------------------------------------------
REATE VIEW  Gold.Dim_products AS
SELECT 
ROW_NUMBER() OVER (ORDER BY pd.prd_start_dt,pd.prd_id) AS PRODUCT_KEY,
pd.prd_id AS PRODUCT_ID,
pd.prd_key AS PRODUCT_NUMBER,
pd.cat_key AS CATEORY_KEY,

pd.prd_nm AS PRODUCT_NAME,
pc.cat AS CATEORY,
pc.subcat AS SUBCATECORY,
pc.maintenance AS MAINTAINENCE,
pd.prd_cost AS PRODUCT_COST,
pd.prd_line AS PRODUCT_LINE,
pd.prd_start_dt AS PRODUCT_START_DATE,
pd.prd_end_dt AS PRODUCT_END_DATE
FROM silver.crm_prd_info as pd
LEFT JOIN [Silver].[erp_PX_CAT_G1V2] AS pc
ON PD.cat_key =pc.id
WHERE pd.prd_end_dt IS NULL ---Filter out all historical data only current data reflecting
