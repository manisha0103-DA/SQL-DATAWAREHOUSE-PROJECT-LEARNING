SQL SCRIPT--Gold_Fact_sales
-----------------------------------------------------------------------------------------------------------
/* since it is connecting multiple dimensions we can    using surrogationg keys to connect the 
multiple dimension known as data look up*/

CREATE VIEW Gold.Fact_Sales AS
SELECT 
       sd.sls_ord_num AS ORDER_NUMBER
       ,cu.surro_key AS CUSTOMER_KEY
      ,pr.product_key AS PRODUCT_KEY
      ,sd.sls_order_d AS SALES_ORDER_DETAILS
      ,sd.sls_ship_dt AS SALES_SHIPPING_DATE
      ,sd.sls_due_dt AS SALES_DUE_DATE
      ,sd.sls_sales AS SALES
      ,sd.sls_quantity AS SALES_QTY
      ,sd.sls_price AS PRICE
      ,sd.dwh_create_date
  FROM [Datawarehouse].[Silver].[crm_sales_details] as sd
  LEFT JOIN Gold.[Dim_products] AS  pr  
  ON sd.sls_prd_key = pr.product_NUMBER
  LEFT JOIN [Gold].[Dim_Customers] cu
  ON sd.sls_cust_id = cu.customer_id

